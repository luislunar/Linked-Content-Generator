ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — for image generation via gpt-image-2 (ChatGPT Images 2.0, released Apr 2026)
# Fallback chain: gpt-image-2 → gpt-image-1 → DALL-E 3
# Cost: token-based pricing (medium quality ~$0.04-0.08/image depending on complexity)
# NOTE: ChatGPT Plus subscription does NOT include API access.
#       API billing is separate at platform.openai.com → Billing → Add payment method
# Get API key at: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Zapier — publishes to LinkedIn via webhook (replaces Blotato + LinkedIn API)
# Setup: zapier.com → New Zap → Webhooks by Zapier (Catch Hook) → LinkedIn (Create Share)
# Copy the "Catch Hook" URL here
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXX/XXXXXX/

# Notion (post tracking + experiments)
NOTION_TOKEN=secret_...
NOTION_POSTS_DB_ID=
NOTION_EXPERIMENTS_DB_ID=

# Optional fallback image generation (free, no billing required)
# Get at: huggingface.co/settings/tokens
# HUGGINGFACE_API_TOKEN=hf_...

# Reddit scraping: no env vars needed (uses public JSON endpoint)
